#!/bin/sh

echo "Running linter..."
ruff check .

if [ $? -ne 0 ]; then
    echo "Linting failed. Commit aborted."
    exit 1
fi

echo "Checking formatting..."
ruff format --check .

if [ $? -ne 0 ]; then
    echo "Formatting check failed. Run 'ruff format .' to fix. Commit aborted."
    exit 1
fi

echo "All checks passed. Proceeding with commit."
exit 0
